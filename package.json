{
  "name": "@chardetm/html-syntax-checker",
  "version": "0.4.8",
  "description": "HTML and CSS syntax checker with easy to understand feedback for beginners in English or French.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vite manual-test",
    "clean": "rimraf dist"
  },
  "keywords": [
    "html",
    "css",
    "syntax",
    "checker",
    "validator",
    "french",
    "english",
    "beginner",
    "beginners",
    "typescript"
  ],
  "author": "Maverick Chardet",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "rimraf": "^6.1.3",
    "typescript": "6.0.3",
    "vite": "^8.1.2",
    "vitest": "4.1.9"
  }
}